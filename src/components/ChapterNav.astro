---
interface Props {
	bookSlug: string;
	currentChapter: number;
	totalChapters: number;
}

const { bookSlug, currentChapter, totalChapters } = Astro.props;

const prevChapter = currentChapter > 1 ? currentChapter - 1 : null;
const nextChapter = currentChapter < totalChapters ? currentChapter + 1 : null;
---

<nav class="flex items-center justify-between py-4 border-t border-stone-200 mt-8">
	<div>
		{prevChapter ? (
			<a
				href={`/${bookSlug}/${prevChapter}`}
				class="inline-flex items-center gap-2 px-4 py-2 text-stone-600 hover:text-stone-900 hover:bg-stone-100 rounded-lg transition"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="m15 18-6-6 6-6"/>
				</svg>
				Chapter {prevChapter}
			</a>
		) : (
			<span></span>
		)}
	</div>

	<a
		href={`/${bookSlug}`}
		class="px-4 py-2 text-stone-600 hover:text-stone-900 hover:bg-stone-100 rounded-lg transition"
	>
		All Chapters
	</a>

	<div>
		{nextChapter ? (
			<a
				href={`/${bookSlug}/${nextChapter}`}
				class="inline-flex items-center gap-2 px-4 py-2 text-stone-600 hover:text-stone-900 hover:bg-stone-100 rounded-lg transition"
			>
				Chapter {nextChapter}
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="m9 18 6-6-6-6"/>
				</svg>
			</a>
		) : (
			<span></span>
		)}
	</div>
</nav>
