---
interface Props {
	number: number;
	greekText: string;
	englishText: string;
}

const { number, greekText, englishText } = Astro.props;

// Split English into clickable words
const englishWords = englishText.split(/(\s+)/).filter(w => w.trim());
---

<div class="interlinear-verse" data-verse={number}>
	<span class="verse-number">{number}</span>

	<div class="verse-content">
		<p class="greek-line" set:html={greekText} />
		<p class="english-line">
			{englishWords.map((word, i) => (
				word.match(/^\s+$/) ? word : (
					<span class="english-word" data-word-index={i}>{word}</span>
				)
			))}
		</p>
	</div>
</div>

<style>
	.interlinear-verse {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
		padding: 0.75rem;
		border-radius: 0.5rem;
		transition: background-color 0.2s;
	}

	.interlinear-verse:hover {
		background-color: #fafaf9;
	}

	.interlinear-verse.highlighted {
		background-color: #fefce8;
	}

	.interlinear-verse:has(.greek-word.highlighted) {
		background-color: transparent;
	}

	.interlinear-verse:has(.greek-word.highlighted):hover {
		background-color: #fafaf9;
	}

	.verse-number {
		font-size: 0.75rem;
		font-weight: 600;
		color: #78716c;
		min-width: 1.5rem;
		padding-top: 0.25rem;
		font-family: system-ui, sans-serif;
	}

	.verse-content {
		flex: 1;
	}

	.greek-line {
		font-family: "Libertinus Serif Display", Georgia, serif;
		font-size: 1.125rem;
		line-height: 1.8;
		margin-bottom: 0.25rem;
	}

	.greek-line :global(.greek-word) {
		text-decoration: underline;
		text-decoration-color: #d6d3d1;
		text-underline-offset: 3px;
		cursor: pointer;
		transition: all 0.15s ease;
		border-radius: 2px;
	}

	.greek-line :global(.greek-word:hover),
	.greek-line :global(.greek-word.highlighted) {
		text-decoration-color: #3b82f6;
		color: #1d4ed8;
		background-color: #dbeafe;
	}

	.english-line {
		font-family: Georgia, serif;
		font-size: 1rem;
		line-height: 1.6;
		color: #57534e;
		font-style: italic;
	}

	.english-word {
		cursor: pointer;
		padding: 0 1px;
		border-radius: 2px;
		transition: all 0.15s ease;
	}

	.english-word:hover,
	.english-word.highlighted {
		background-color: #dbeafe;
		color: #1d4ed8;
	}
</style>
