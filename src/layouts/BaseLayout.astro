---
import "../styles/global.css";

interface Props {
	title?: string;
}

const { title = "Septuagint Interactive" } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Interactive Greek Septuagint with Strong's definitions" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Libertinus+Serif+Display&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="bg-stone-50 text-stone-900 min-h-screen">
		<header class="border-b border-stone-200 bg-white">
			<nav class="max-w-4xl mx-auto px-4 py-3 flex items-center gap-4">
				<a href="/" class="font-bold text-lg hover:text-stone-600">Septuagint</a>
				<slot name="breadcrumbs" />
			</nav>
		</header>
		<main class="max-w-4xl mx-auto px-4 py-8">
			<slot />
		</main>
		<footer class="border-t border-stone-200 mt-12 py-6 text-center text-stone-500 text-sm">
			<p>Greek text from the Septuagint (LXX)</p>
			<p>Strong's definitions via <a href="https://bolls.life" class="underline hover:text-stone-700" target="_blank" rel="noopener">Bolls.life API</a></p>
		</footer>
	</body>
</html>
